---
import SkillsModal from "./SkillsModal.astro";
import ProjectsModal from "./ProjectsModal.astro";
import ContactModal from "./ContactModal.astro";
import ExperienceModal from "./ExperienceModal.astro";
import Footer from "../components/Footer.astro";
---

<div
  class="main flex font-bold w-full min-h-screen justify-center items-center flex-col gap-6 py-20 px-6"
>
  <div
    class="w-28 h-28 md:w-36 md:h-36 rounded-full overflow-hidden border border-gray-300 dark:border-gray-700 shrink-0"
  >
    <img
      src="/pic.jpg"
      alt="Profile Picture"
      class="w-full h-full object-cover"
    />
  </div>
  <div class="text-center space-y-2">
    <h1 class="text-3xl md:text-4xl font-medium">Richard Banguiz</h1>
    <p class="text-lg md:text-xl font-thin text-gray-600 dark:text-gray-400">
      Full Stack Developer & Coding Instructor
    </p>
  </div>
  <p
    class="text-sm md:text-base font-thin w-full max-w-2xl text-center text-gray-700 dark:text-gray-300 leading-relaxed"
  >
    5+ years of expertise in architecting dependable web ecosystems. I bridge
    the gap between complex infrastructure and practical, maintainable software
    design.
  </p>
  <ul
    class="w-full max-w-3xl flex flex-wrap gap-x-6 gap-y-3 justify-center text-sm md:text-base font-thin"
  >
    <li
      class="hover:text-black dark:hover:text-white duration-150 text-gray-600 dark:text-gray-400 hover:scale-105 transition-all"
    >
      <a href='http://github.com/urkiddennn"'>Github</a>
    </li>
    <li
      class="hover:text-black dark:hover:text-white duration-150 text-gray-600 dark:text-gray-400 hover:scale-105 transition-all"
    >
      <a href="">LinkedIn</a>
    </li>
    <li
      class="hover:text-black dark:hover:text-white duration-150 text-gray-600 dark:text-gray-400 hover:scale-105 transition-all"
    >
      <a href="https://x.com/Urkidden2">X</a>
    </li>
    <li
      class="hover:text-black dark:hover:text-white duration-150 text-gray-600 dark:text-gray-400 hover:scale-105 transition-all"
    >
      <button id="experience-trigger" class="cursor-pointer">Experience</button>
    </li>
    <li
      class="hover:text-black dark:hover:text-white duration-150 text-gray-600 dark:text-gray-400 hover:scale-105 transition-all"
    >
      <button id="skills-trigger" class="cursor-pointer">Skills</button>
    </li>
    <li
      class="hover:text-black dark:hover:text-white duration-150 text-gray-600 dark:text-gray-400 hover:scale-105 transition-all"
    >
      <button id="contact-trigger" class="cursor-pointer">Contact</button>
    </li>
    <li
      class="hover:text-black dark:hover:text-white duration-150 text-gray-600 dark:text-gray-400 hover:scale-105 transition-all"
    >
      <button id="projects-trigger" class="cursor-pointer">Projects</button>
    </li>
  </ul>
  <SkillsModal />
  <ProjectsModal />
  <ContactModal />
  <ExperienceModal />
  <Footer />
</div>

<script>
  const skillsTrigger = document.getElementById("skills-trigger");
  const contactTrigger = document.getElementById("contact-trigger");
  const projectsTrigger = document.getElementById("projects-trigger");
  const experienceTrigger = document.getElementById("experience-trigger");
  const skillsModal = document.getElementById(
    "skills-modal",
  ) as HTMLDialogElement;
  const projectsModal = document.getElementById(
    "projects-modal",
  ) as HTMLDialogElement;

  const contactModal = document.getElementById(
    "contact-modal",
  ) as HTMLDialogElement;

  const experienceModal = document.getElementById(
    "experience-modal",
  ) as HTMLDialogElement;

  skillsTrigger?.addEventListener("click", () => {
    skillsModal?.showModal();
  });

  contactTrigger?.addEventListener("click", () => {
    contactModal?.showModal();
  });

  projectsTrigger?.addEventListener("click", () => {
    projectsModal?.showModal();
  });

  experienceTrigger?.addEventListener("click", () => {
    experienceModal?.showModal();
  });
</script>
